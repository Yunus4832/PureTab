{
  "manifest_version": 3,
  "name": "PureTab",
  "description": "A clean, customizable new tab page with search engine switching, custom visuals, history, and bookmark suggestions.",
  "version": "0.2.2",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "puretab@example.com",
      "strict_min_version": "109.0"
    }
  }
}
