{
  "manifest_version": 3,
  "name": "PureTab",
  "description": "A customizable new tab page that respects your browser's default search provider and offers per-search provider choices.",
  "version": "0.3.2",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "search"
  ],
  "optional_permissions": [
    "history"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "puretab@example.com",
      "strict_min_version": "111.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
